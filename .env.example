# OpenAI API 配置 (通过 xiaoai.plus 代理)
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_BASE_URL=https://xiaoai.plus/v1

# DeepSeek API 配置
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Coze API 配置
COZE_ACCESS_TOKEN=Bearer pat-your-coze-access-token
COZE_WORKFLOW_ID=your-workflow-id
COZE_APP_ID=your-app-id

# Milvus 数据库配置
MILVUS_HOST=localhost
MILVUS_PORT=19530

# 向量嵌入模型路径
EMBEDDINGS_MODEL_PATH=/path/to/bge-large-zh-v1.5
